{
  "name": "evalsupport-ai",
  "version": "0.1.0",
  "description": "A local-first, testable RAG support agent with citations, fallback tickets, BYOK chat, admin tracking, and smoke tests.",
  "private": true,
  "license": "MIT",
  "keywords": [
    "rag",
    "ai-agent",
    "customer-support",
    "nextjs",
    "pgvector",
    "openai-compatible",
    "portfolio"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:conversation": "node scripts/conversation-test.mjs",
    "test:admin": "node scripts/admin-regression-test.mjs",
    "test:docs": "node scripts/docs-link-check.mjs",
    "test:safety": "node scripts/repo-safety-check.mjs",
    "test:portfolio": "node scripts/portfolio-check.mjs",
    "mock:ai": "node scripts/mock-openai-compatible.mjs",
    "supabase:version": "supabase --version",
    "supabase:start": "supabase start",
    "supabase:db:reset": "supabase db reset",
    "supabase:db:push": "supabase db push"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "pdf-parse": "^2.4.5",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "supabase": "^2.108.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
